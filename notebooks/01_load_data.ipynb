   "source": [
    "import numpy as np\n",
    "\n",
    "npx_path = \"data/raw/c37_npx_raw.bin\"\n",
    "npx_channels = 384\n",
    "npx_samples = 4050171\n",
    "\n",
    "npx_recording = np.memmap(npx_path, mode='r', dtype=np.int16, order='C')\n",
    "npx_recording = npx_recording.reshape((npx_channels, npx_samples), order='F')\n",
    "print(f\"Recording shape: {npx_recording.shape}\")\n",
    "\n",
    "ground_truth_spikes = np.load(\"data/raw/c37_extracellular_spikes.npy\")\n",
    "print(f\"Ground truth spikes: {len(ground_truth_spikes)}\")\n",
    "print(ground_truth_spikes[:10])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "9fc9368f-aad1-4bee-a880-ee1852f2e1f5",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x800 with 5 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fs = 30000,
    "channels_to_plot = [195, 196, 197, 198, 199]\n",
    "window_samples = int(fs * 1)  # 1 second\n",
    "\n",
    "fig, axes = plt.subplots(len(channels_to_plot), 1, figsize=(12, 8), sharex=True)\n",
    "for i, ch in enumerate(channels_to_plot):\n",
    "    axes[i].plot(npx_recording[ch, :window_samples])\n",
    "    axes[i].set_ylabel(f\"Ch {ch}\")\n",
    "plt.xlabel(\"Sample\")\n",
    "plt.suptitle(\"Channels near ground truth neuron\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"figures/raw_channels.png\")\n",
    "plt.show()"
   ]
  },
